<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user, currentPath }) %>

<div class="page-header">
  <h1>Dashboard</h1>
  <p class="lead">Welcome back, <strong><%= user.displayName %></strong> · <%= user.email %></p>
</div>

<% if (paymentSuccess && paymentEndToEndId) { %>
<div class="alert success">
  Payment <span class="mono"><%= paymentEndToEndId %></span> settled successfully (<strong>ACSC</strong>).
  Your balance and statement have been updated.
  <a href="/payer/payments/status?endToEndId=<%= encodeURIComponent(paymentEndToEndId) %>">View pain.002 →</a>
</div>
<% } %>

<div class="toolbar">
  <div class="status-row">
    <% if (health?.status === 'ok') { %>
    <span class="badge ok">API online</span>
    <% } else { %>
    <span class="badge warn">API offline</span>
    <% } %>
    <% if (ready?.status === 'ok') { %>
    <span class="badge ok">Database ready</span>
    <% } else if (ready !== null) { %>
    <span class="badge warn">Database unavailable</span>
    <% } %>
  </div>
  <a class="btn" href="/payer/payment/new">Send payment</a>
</div>

<div class="grid-2">
  <section class="card balance-hero">
    <p class="card-eyebrow">Available balance</p>
    <p class="account-name"><%= account.owner.nm %></p>
    <p class="balance-amount">
      <%= account.bal.value %><span class="currency"><%= account.bal.ccy %></span>
    </p>
    <p class="account-id"><%= account.id %></p>
    <p style="margin-top:1rem"><span class="badge"><%= account.status %></span></p>
  </section>

  <section class="card">
    <h2>ISO 20022 messages</h2>
    <ul class="iso-list">
      <li>
        <span class="iso-code">pain.001</span>
        <span>Submit credit transfer initiation</span>
      </li>
      <li>
        <span class="iso-code">pain.002</span>
        <span><a href="/payer/payments/status">Look up payment status</a></span>
      </li>
      <li>
        <span class="iso-code">camt.053</span>
        <span>Account statement entries below</span>
      </li>
    </ul>
  </section>
</div>

<section class="card">
  <div class="card-section-title">
    <h2>Account statement</h2>
    <span class="badge ok">camt.053</span>
  </div>
  <%- include('../partials/statement-table', {
    statement,
    e2eLinkPrefix: '/payer/payments/status?endToEndId=',
    paginationHref: '/payer',
    cursor,
  }) %>
</section>

<%- include('../partials/footer') %>
