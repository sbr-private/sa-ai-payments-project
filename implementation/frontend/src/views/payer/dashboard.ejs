<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user }) %>

<h1>Payer Portal</h1>
<p class="muted">Signed in as <%= user.displayName %> (<%= user.email %>)</p>

<div class="status-row" style="margin-bottom:1rem">
  <% if (health?.status === 'ok') { %>
  <span class="badge ok">API connected</span>
  <% } else { %>
  <span class="badge warn">API unavailable</span>
  <% } %>
  <a class="btn" href="/payer/payment/new">Send payment</a>
</div>

<div class="grid-2">
  <section class="card">
    <h2>Account balance</h2>
    <p class="mono"><%= account.owner.nm %></p>
    <p style="font-size:1.6rem;font-weight:700;margin:0.5rem 0">
      <%= account.bal.value %> <%= account.bal.ccy %>
    </p>
    <p class="muted mono"><%= account.id %></p>
    <p>Status: <span class="badge ok"><%= account.status %></span></p>
  </section>

  <section class="card">
    <h2>ISO messages</h2>
    <ul>
      <li><strong>pain.001</strong> — submit credit transfer initiation</li>
      <li><strong>pain.002</strong> — payment status report</li>
      <li><strong>camt.053</strong> — account statement</li>
    </ul>
  </section>
</div>

<section class="card">
  <h2>Recent statement (camt.053)</h2>
  <% if (!statement?.stmt?.ntry?.length) { %>
  <p class="muted">No statement entries yet.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>EndToEndId</th>
        <th>Direction</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      <% statement.stmt.ntry.forEach(function(entry) { %>
      <tr>
        <td><%= entry.bookgDt.dt %></td>
        <td class="mono">
          <%= entry.ntryDtls?.[0]?.txDtls?.[0]?.refs?.endToEndId || '—' %>
        </td>
        <td><%= entry.cdtDbtInd %></td>
        <td><%= entry.amt.value %> <%= entry.amt.ccy %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include('../partials/footer') %>
