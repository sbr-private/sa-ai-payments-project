<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user, currentPath }) %>

<div class="page-header">
  <h1>Payment status</h1>
  <p class="lead">Look up your payments by <%- include('../partials/term', terms.endToEndId) %></p>
</div>

<section class="card">
  <form class="stack" method="get" action="/payer/payments/status">
    <label>
      <%- include('../partials/term', terms.endToEndId) %>
      <input class="mono" name="endToEndId" maxlength="35" value="<%= endToEndId %>" placeholder="E2E-INV-2024-0558" />
    </label>
    <button class="btn" type="submit">Look up payment</button>
  </form>
  <p class="muted" style="margin:1rem 0 0;font-size:0.85rem">Or pick a reference from your <a href="/payer">account statement</a>.</p>
</section>

<% if (error) { %>
<div class="alert <%= lookupUnavailable ? 'warning' : 'error' %>"><%= error %></div>
<% } %>

<% if (result) { %>
<section class="card">
  <div class="card-section-title">
    <h2>Payment result</h2>
    <%- include('../partials/status-badge', { code: result.txSts, statusInfo: formatTxStatus(result.txSts) }) %>
  </div>
  <p><%- include('../partials/term', terms.endToEndId) %><br><span class="mono"><%= result.orgnlEndToEndId %></span></p>

  <% if (result.stsRsnInf?.length) { %>
  <h3 style="margin-top:1.5rem;font-size:0.9rem"><%- include('../partials/term', terms.rejectionReason) %></h3>
  <% result.stsRsnInf.forEach(function(item) { %>
  <% const reason = formatReasonCode(item.rsn.cd); %>
  <p>
    <span class="term-hint" tabindex="0">
      <span class="term-label"><%= reason.label %></span>
      <span class="term-tooltip" role="tooltip">
        <span class="term-technical"><%= item.rsn.cd %> (<%= terms.reasonCode.technical %>)</span>
        <%= reason.definition %>
      </span>
    </span>
  </p>
  <% if (item.addtlInf?.length) { %>
  <p class="muted"><%= item.addtlInf.join(' ') %></p>
  <% } %>
  <% }) %>
  <% } %>

  <details>
    <summary>Technical response (JSON)</summary>
    <pre class="mono"><%= JSON.stringify(result, null, 2) %></pre>
  </details>
</section>
<% } %>

<%- include('../partials/footer') %>
