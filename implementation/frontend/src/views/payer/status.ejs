<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user, currentPath }) %>

<div class="page-header">
  <h1>Payment status</h1>
  <p class="lead">Look up your payments by <strong>endToEndId</strong> — pain.002 status report</p>
</div>

<section class="card">
  <form class="stack" method="get" action="/payer/payments/status">
    <label>
      EndToEndId
      <input class="mono" name="endToEndId" maxlength="35" value="<%= endToEndId %>" placeholder="E2E-INV-2024-0558" />
    </label>
    <button class="btn" type="submit">Look up payment</button>
  </form>
  <p class="muted" style="margin:1rem 0 0;font-size:0.85rem">Or select an EndToEndId from your <a href="/payer">account statement</a>.</p>
</section>

<% if (error) { %>
<div class="alert <%= lookupUnavailable ? 'warning' : 'error' %>"><%= error %></div>
<% } %>

<% if (result) { %>
<section class="card">
  <div class="card-section-title">
    <h2>Transaction status</h2>
    <span class="badge <%= result.txSts === 'ACSC' ? 'ok' : result.txSts === 'RJCT' ? 'err' : 'warn' %>"><%= result.txSts %></span>
  </div>
  <p>EndToEndId<br><span class="mono"><%= result.orgnlEndToEndId %></span></p>

  <% if (result.stsRsnInf?.length) { %>
  <h3 style="margin-top:1.5rem;font-size:0.9rem">Status reason</h3>
  <% result.stsRsnInf.forEach(function(reason) { %>
  <p>Code <span class="mono"><%= reason.rsn.cd %></span></p>
  <% if (reason.addtlInf?.length) { %>
  <p class="muted"><%= reason.addtlInf.join(' ') %></p>
  <% } %>
  <% }) %>
  <% } %>

  <details>
    <summary>Raw JSON response</summary>
    <pre class="mono"><%= JSON.stringify(result, null, 2) %></pre>
  </details>
</section>
<% } %>

<%- include('../partials/footer') %>
