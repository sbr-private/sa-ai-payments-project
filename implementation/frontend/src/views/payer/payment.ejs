<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user, currentPath }) %>

<div class="page-header">
  <h1>New payment</h1>
  <p class="lead">Send money from <%= account.owner.nm %> · <%= account.bal.value %> <%= account.bal.ccy %> available</p>
</div>

<div class="alert info">
  <strong>Demo tip:</strong> try amount <code>2000.00</code> to see a <strong>rejected</strong> payment due to insufficient funds.
</div>

<% if (error) { %>
<div class="alert error"><%= error %></div>
<% } %>

<div class="grid-2">
  <section class="card">
    <h2><%- include('../partials/term', terms.pain001) %></h2>
    <form class="stack" method="post" action="/payer/payment/new">
      <label>
        <%- include('../partials/term', terms.endToEndId) %>
        <span class="muted" style="font-weight:400"> — <%- include('../partials/term', terms.idempotency) %></span>
        <input class="mono" name="endToEndId" maxlength="35" required value="<%= defaults.endToEndId %>" />
      </label>
      <label>
        Amount
        <input name="amount" required pattern="^[0-9]+(\.[0-9]+)?$" value="<%= defaults.amount %>" />
      </label>
      <label>
        Beneficiary account
        <input class="mono" name="creditorAccountId" required value="<%= supplierAccountId %>" />
      </label>
      <label>
        Payment description
        <span class="muted" style="font-weight:400"> — optional</span>
        <input name="remittance" value="<%= defaults.remittance %>" />
      </label>
      <button class="btn btn-lg" type="submit" style="width:100%">Send payment</button>
    </form>
  </section>

  <section class="card">
    <div class="card-section-title">
      <h2><%- include('../partials/term', terms.pain002) %></h2>
    </div>
    <% if (!result) { %>
    <div class="empty-state">
      <p>Submit a payment to see whether it was accepted or rejected.</p>
      <p class="muted" style="font-size:0.85rem">Successful payments redirect to your dashboard with an updated balance.</p>
    </div>
    <% } else { %>
    <% const tx = result.orgnlPmtInfAndSts?.[0]?.txInfAndSts?.[0]; %>
    <p>Overall result <strong><%= result.orgnlGrpInfAndSts.grpSts === 'ACSC' ? 'Settled' : result.orgnlGrpInfAndSts.grpSts === 'RJCT' ? 'Rejected' : result.orgnlGrpInfAndSts.grpSts %></strong></p>
    <% if (tx) { %>
    <p style="margin-top:1rem"><%- include('../partials/term', terms.endToEndId) %><br><span class="mono"><%= tx.orgnlEndToEndId %></span></p>
    <p style="margin-top:0.75rem">
      <%- include('../partials/term', terms.txStatus) %>
      <%- include('../partials/status-badge', { code: tx.txSts, statusInfo: formatTxStatus(tx.txSts) }) %>
    </p>
    <% if (tx.stsRsnInf?.length) { %>
    <% const reason = formatReasonCode(tx.stsRsnInf[0].rsn.cd); %>
    <p style="margin-top:0.75rem">
      <span class="term-hint" tabindex="0">
        <span class="term-label"><%= reason.label %></span>
        <span class="term-tooltip" role="tooltip">
          <span class="term-technical"><%= tx.stsRsnInf[0].rsn.cd %> (<%= terms.reasonCode.technical %>)</span>
          <%= reason.definition %>
        </span>
      </span>
    </p>
    <p class="muted"><%= tx.stsRsnInf[0].addtlInf?.join(' ') %></p>
    <% } %>
    <p style="margin-top:1.25rem">
      <a class="btn ghost" href="/payer/payments/status?endToEndId=<%= encodeURIComponent(tx.orgnlEndToEndId) %>">View full status</a>
    </p>
    <% } %>
    <details>
      <summary>Technical response (JSON)</summary>
      <pre class="mono"><%= JSON.stringify(result, null, 2) %></pre>
    </details>
    <% } %>
  </section>
</div>

<%- include('../partials/footer') %>
