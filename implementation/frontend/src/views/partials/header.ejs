<header class="site-header">
  <div class="container">
    <a class="brand" href="<%= typeof user !== 'undefined' && user ? (user.role === 'support' ? '/support' : '/payer') : '/login' %>">
      <%- include('brand-mark') %>
      <span class="brand-text">
        <span class="brand-name">AmazingPayments</span>
        <span class="brand-tag">ISO 20022 · pain.001 · camt.053</span>
      </span>
    </a>
    <% if (typeof user !== 'undefined' && user) { %>
    <nav class="nav-links">
      <% if (user.role === 'payer') { %>
      <a class="nav-link<%= typeof currentPath !== 'undefined' && currentPath === '/payer' ? ' active' : '' %>" href="/payer">Dashboard</a>
      <a class="nav-link<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/payer/payment') ? ' active' : '' %>" href="/payer/payment/new">Send payment</a>
      <a class="nav-link<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/payer/payments') ? ' active' : '' %>" href="/payer/payments/status">Status</a>
      <% } %>
      <% if (user.role === 'support') { %>
      <a class="nav-link<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/support') ? ' active' : '' %>" href="/support">Investigate</a>
      <% } %>
      <a class="nav-link" href="/api-docs/ledger" target="_blank" rel="noreferrer">API</a>
      <form class="nav-form" action="/logout" method="post">
        <button class="btn secondary" type="submit">Sign out</button>
      </form>
    </nav>
    <% } %>
  </div>
</header>
<main class="container">
