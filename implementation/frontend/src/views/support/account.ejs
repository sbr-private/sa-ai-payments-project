<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user, currentPath }) %>

<a class="back-link" href="/support">← Back to search</a>

<div class="page-header">
  <h1><%= account.owner.nm %></h1>
  <p class="lead mono"><%= account.id %></p>
</div>

<div class="grid-2">
  <section class="card balance-hero">
    <p class="card-eyebrow">Current balance</p>
    <p class="balance-amount">
      <%= account.bal.value %><span class="currency"><%= account.bal.ccy %></span>
    </p>
    <p style="margin-top:1rem"><span class="badge"><%= account.status %></span></p>
  </section>

  <section class="card">
    <h2>Account details</h2>
    <p>Currency <strong><%= account.ccy %></strong></p>
    <p>Created <span class="mono"><%= account.creDtTm %></span></p>
  </section>
</div>

<section class="card">
  <div class="card-section-title">
    <h2>Statement</h2>
    <span class="badge ok">camt.053</span>
  </div>
  <%- include('../partials/statement-table', {
    statement,
    e2eLinkPrefix: '/support/search?endToEndId=',
    paginationHref: '/support/accounts/' + accountId,
    cursor,
  }) %>
</section>

<%- include('../partials/footer') %>
