<%- include('../partials/head', { title }) %>
<%- include('../partials/header', { user }) %>

<p><a href="/support">← Back to search</a></p>

<h1><%= account.owner.nm %></h1>
<p class="muted mono"><%= account.id %></p>

<div class="grid-2">
  <section class="card">
    <h2>Balance</h2>
    <p style="font-size:1.6rem;font-weight:700;margin:0">
      <%= account.bal.value %> <%= account.bal.ccy %>
    </p>
    <p>Status: <span class="badge ok"><%= account.status %></span></p>
  </section>

  <section class="card">
    <h2>Account details</h2>
    <p>Currency: <%= account.ccy %></p>
    <p>Created: <%= account.creDtTm %></p>
  </section>
</div>

<section class="card">
  <h2>Statement (camt.053)</h2>
  <% if (!statement?.stmt?.ntry?.length) { %>
  <p class="muted">No entries.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>EndToEndId</th>
        <th>Direction</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      <% statement.stmt.ntry.forEach(function(entry) { %>
      <tr>
        <td><%= entry.bookgDt.dt %></td>
        <td class="mono">
          <% const e2e = entry.ntryDtls?.[0]?.txDtls?.[0]?.refs?.endToEndId; %>
          <% if (e2e) { %>
          <a href="/support/search?endToEndId=<%= encodeURIComponent(e2e) %>"><%= e2e %></a>
          <% } else { %>—<% } %>
        </td>
        <td><%= entry.cdtDbtInd %></td>
        <td><%= entry.amt.value %> <%= entry.amt.ccy %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include('../partials/footer') %>
